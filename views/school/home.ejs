<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <meta name="description"
        content="N.R.K. Public School - A Unit of Nageshwaram Foundation Trust. Providing quality education in Jamui.">

    <!-- Fonts & Icons -->
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <!-- FontAwesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- Custom Styles -->
    <link href="/css/style.css" rel="stylesheet">
    <link href="/css/complete-fix.css" rel="stylesheet">
    <!-- Carousel Script -->
    <script src="/js/carousel.js" defer></script>

    <style>
        .school-hero {
            position: relative;
            height: 90vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            padding-top: 80px;
            overflow: hidden;
        }

        /* Carousel Styles */
        .hero-carousel {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
        }

        .carousel-slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            transition: opacity 1s ease-in-out;
        }

        .carousel-slide.active {
            opacity: 1;
        }

        .carousel-slide::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(10, 38, 71, 0.5);
            z-index: 1;
        }

        .carousel-slide img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center center;
        }

        .hero-content {
            position: relative;
            z-index: 2;
        }

        .hero-content h1 {
            color: #FFD700 !important;
            /* Vibrant Gold */
            text-shadow: 0 4px 12px rgba(0, 0, 0, 0.8),
                0 2px 4px rgba(0, 0, 0, 0.6),
                0 10px 20px rgba(0, 0, 0, 0.4) !important;
            font-weight: 700 !important;
            letter-spacing: 0.5px !important;
            font-size: 4rem;
            margin-bottom: 20px;
        }

        .hero-content p {
            color: #FFD700 !important;
            /* Unified Gold */
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.8),
                0 1px 2px rgba(0, 0, 0, 0.6) !important;
            font-weight: 500 !important;
            font-size: 1.4rem;
            letter-spacing: 0.3px;
            max-width: 800px;
            margin: 0 auto 30px auto;
        }

        /* Carousel Navigation */
        .carousel-dots {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 10px;
            z-index: 3;
        }

        .carousel-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.5);
            cursor: pointer;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }

        .carousel-dot.active {
            background: var(--accent-gold);
            border-color: white;
            transform: scale(1.2);
        }

        .carousel-arrow {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255, 255, 255, 0.2);
            color: white;
            border: none;
            padding: 15px 20px;
            cursor: pointer;
            font-size: 1.5rem;
            transition: all 0.3s ease;
            z-index: 3;
            border-radius: 4px;
        }

        .carousel-arrow:hover {
            background: rgba(255, 255, 255, 0.3);
        }

        .carousel-arrow.prev {
            left: 20px;
        }

        .carousel-arrow.next {
            right: 20px;
        }

        /* Mobile Responsiveness */
        @media (max-width: 768px) {
            .school-hero {
                height: 60vh;
                min-height: 500px;
                padding-top: 60px;
            }

            .carousel-slide img {
                object-fit: cover;
                object-position: center center;
            }

            .carousel-arrow {
                padding: 10px 15px;
                font-size: 1.2rem;
            }

            .carousel-arrow.prev {
                left: 10px;
            }

            .carousel-arrow.next {
                right: 10px;
            }

            .carousel-dots {
                bottom: 15px;
            }

            .carousel-dot {
                width: 10px;
                height: 10px;
            }

            .hero-content h1 {
                font-size: 2.5rem !important;
            }

            .hero-content p {
                font-size: 1.1rem !important;
            }
        }

        @media (max-width: 480px) {
            .school-hero {
                height: 55vh;
                min-height: 450px;
            }

            .hero-content h1 {
                font-size: 2rem !important;
            }

            .hero-content p {
                font-size: 1rem !important;
                padding: 0 15px;
            }

            .carousel-arrow {
                padding: 8px 12px;
                font-size: 1rem;
            }
        }

        .school-stats {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            padding: 60px 0;
            background: var(--primary-blue);
            color: white;
        }

        .stat-item {
            text-align: center;
            margin: 20px;
        }

        .stat-number {
            font-size: 3rem;
            font-family: 'Playfair Display', serif;
            color: var(--accent-gold);
            font-weight: bold;
        }

        .feature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
            margin-top: 50px;
        }

        .feature-card {
            background: white;
            padding: 40px;
            border-radius: 8px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition-fast);
            border-left: 5px solid var(--accent-gold);
        }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: var(--shadow-lg);
        }

        .testimonial-section {
            background: var(--bg-cream);
            padding: 80px 0;
            text-align: center;
        }

        .testimonial-card {
            background: white;
            padding: 40px;
            max-width: 800px;
            margin: 0 auto;
            border-radius: 8px;
            box-shadow: var(--shadow-md);
            position: relative;
        }

        .quote-icon {
            color: var(--accent-gold);
            font-size: 2rem;
            margin-bottom: 20px;
        }
    </style>
</head>

<body>
    <%- include('../partials/school_header') %>

        <main>
            <!-- Hero Section with Carousel -->
            <section class="school-hero">
                <!-- Carousel Background -->
                <div class="hero-carousel">
                    <div class="carousel-slide active">
                        <img src="/images/cursouse_image1_0226.jpeg" alt="School Campus">
                    </div>
                    <div class="carousel-slide">
                        <img src="/images/cursouse_image2_0226.jpeg" alt="School Building">
                    </div>
                    <div class="carousel-slide">
                        <img src="/images/cursouse_image3_0226.jpeg" alt="School Facilities">
                    </div>
                    <div class="carousel-slide">
                        <img src="/images/Curouse_image4_0226.jpeg" alt="School Campus View">
                    </div>
                </div>

                <!-- Navigation Arrows -->
                <button class="carousel-arrow prev" onclick="moveSlide(-1)">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <button class="carousel-arrow next" onclick="moveSlide(1)">
                    <i class="fas fa-chevron-right"></i>
                </button>

                <!-- Hero Content -->
                <div class="container hero-content">
                    <p
                        style="font-size: 1.2rem; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 20px; color: #FFD700 !important; text-shadow: 0 2px 4px rgba(0,0,0,0.8);">
                        Excellence in Education</p>
                    <h1
                        style="font-size: 4rem; color: white; margin-bottom: 30px; text-shadow: 0 4px 10px rgba(0,0,0,0.3);">
                        Welcome to N.R.K. Public School</h1>
                    <p
                        style="font-size: 1.3rem; max-width: 800px; margin: 0 auto 40px auto; opacity: 1; text-shadow: 0 2px 5px rgba(0,0,0,0.5);">
                        Empowering students with knowledge, character, and skills to succeed in a global world.
                    </p>
                    <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
                        <a href="/school/admissions" class="cta-button gold">Admissions 2026-27</a>
                        <a href="/school/about" class="cta-button secondary"
                            style="border-color: white; color: white;">Discover More</a>
                    </div>
                </div>

                <!-- Carousel Dots -->
                <div class="carousel-dots">
                    <span class="carousel-dot active" onclick="currentSlide(0)"></span>
                    <span class="carousel-dot" onclick="currentSlide(1)"></span>
                    <span class="carousel-dot" onclick="currentSlide(2)"></span>
                    <span class="carousel-dot" onclick="currentSlide(3)"></span>
                </div>
            </section>

            <!-- Stats Section -->
            <section class="school-stats">
                <div class="container" style="display: flex; justify-content: space-around; flex-wrap: wrap;">
                    <div class="stat-item">
                        <div class="stat-number">500+</div>
                        <div class="stat-label">Happy Students</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">25+</div>
                        <div class="stat-label">Expert Faculty</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">100%</div>
                        <div class="stat-label">Result Record</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">10+</div>
                        <div class="stat-label">Acres Campus</div>
                    </div>
                </div>
            </section>

            <!-- Welcome / Intro -->
            <section class="section-padding" style="background: white;">
                <div class="container">
                    <div class="row" style="display: flex; align-items: center; gap: 50px; flex-wrap: wrap;">
                        <div class="col" style="flex: 1; min-width: 300px;">
                            <h2 style="font-size: 2.5rem;">Nurturing Tomorrow's Leaders</h2>
                            <p style="margin-bottom: 20px; color: var(--text-gray); font-size: 1.1rem;">
                                At N.R.K. Public School, we go beyond textbooks. We believe in an education that builds
                                character, fosters creativity, and instills a sense of responsibility.
                            </p>
                            <p style="margin-bottom: 30px; color: var(--text-gray); font-size: 1.1rem;">
                                Our campus is a vibrant community where tradition meets technology, ensuring your child
                                gets the best of both worlds.
                            </p>
                            <ul style="margin-bottom: 30px; display: grid; gap: 10px;">
                                <li><i class="fas fa-check-circle text-gold" style="margin-right: 10px;"></i> Modern
                                    Smart Classrooms</li>
                                <li><i class="fas fa-check-circle text-gold" style="margin-right: 10px;"></i> Holistic
                                    Development Programs</li>
                                <li><i class="fas fa-check-circle text-gold" style="margin-right: 10px;"></i> Safe &
                                    Secure Environment</li>
                            </ul>
                            <a href="/school/directors-message" class="cta-button primary">Director's Message</a>
                        </div>
                        <div class="col" style="flex: 1; min-width: 300px;">
                            <div
                                style="background: var(--bg-cream); padding: 10px; border-radius: 8px; transform: rotate(2deg);">
                                <img src="/images/classroom.png" alt="Smart Classroom"
                                    style="border-radius: 4px; width: 100%; box-shadow: var(--shadow-lg);">
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Features Grid -->
            <section class="section-padding" style="background: var(--bg-cream);">
                <div class="container">
                    <div class="text-center" style="margin-bottom: 60px;">
                        <span class="text-blue" style="font-weight: 600; text-transform: uppercase;">Why Choose
                            Us</span>
                        <h2>A World of Opportunities</h2>
                    </div>

                    <div class="feature-grid">
                        <div class="feature-card">
                            <i class="fas fa-laptop-code fa-3x text-blue" style="margin-bottom: 20px;"></i>
                            <h3>Digital Learning</h3>
                            <p>Fully equipped computer labs and smart classes to ensure our students are future-ready.
                            </p>
                        </div>
                        <div class="feature-card">
                            <i class="fas fa-futbol fa-3x text-blue" style="margin-bottom: 20px;"></i>
                            <h3>Sports & Arts</h3>
                            <p>Expansive playgrounds and dedicated studios for music, dance, and arts promotes physical
                                and mental agility.</p>
                        </div>
                        <div class="feature-card">
                            <i class="fas fa-flask fa-3x text-blue" style="margin-bottom: 20px;"></i>
                            <h3>Science Labs</h3>
                            <p>State-of-the-art physics, chemistry, and biology labs to encourage practical learning and
                                scientific temper.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Testimonial -->
            <section class="testimonial-section">
                <div class="container">
                    <div class="testimonial-card">
                        <i class="fas fa-quote-left quote-icon"></i>
                        <p style="font-size: 1.25rem; font-style: italic; margin-bottom: 30px;">
                            "N.R.K. Public School has transformed my child. The teachers are incredibly supportive, and
                            the focus on values alongside academics is exactly what we were looking for."
                        </p>
                        <div>
                            <h4 style="margin-bottom: 5px;">Mrs. Anjali Singh</h4>
                            <span style="color: var(--text-gray); font-size: 0.9rem;">Parent of Grade 5 Student</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Call to Action -->
            <section style="background: url('/images/cta-bg.png') center/cover; position: relative;">
                <div style="background: rgba(10, 38, 71, 0.9); padding: 100px 0; text-align: center; color: white;">
                    <div class="container">
                        <h2 style="color: white; font-size: 2.5rem; margin-bottom: 20px;">Join the N.R.K. Family</h2>
                        <p style="margin-bottom: 40px; font-size: 1.2rem; opacity: 0.9;">Limited seats available for the
                            2026-27 academic session. Give your child the edge.</p>
                        <a href="/school/admissions" class="cta-button gold">Apply Now</a>
                    </div>
                </div>
            </section>

        </main>

        <%- include('../partials/footer') %>

            <!-- Floating Enquire Now Button -->
            <button id="enquireNowBtn" class="enquire-float-btn" onclick="openEnquiryModal()">
                <i class="fas fa-pen-to-square"></i>
                <span>Enquire Now</span>
            </button>

            <!-- Enquiry Modal Overlay -->
            <div id="enquiryModal" class="enquiry-modal-overlay" onclick="closeEnquiryModalOutside(event)">
                <div class="enquiry-modal">
                    <button class="enquiry-modal-close" onclick="closeEnquiryModal()"
                        aria-label="Close">&times;</button>

                    <!-- Form View -->
                    <div id="enquiryFormView">
                        <div class="enquiry-modal-header">
                            <div class="enquiry-modal-icon">
                                <i class="fas fa-graduation-cap"></i>
                            </div>
                            <h2>Enquire Now</h2>
                            <p>Fill in the details below and our team will get back to you shortly.</p>
                        </div>
                        <form id="enquiryForm" class="enquiry-form" onsubmit="submitEnquiry(event)">
                            <div class="enquiry-form-group">
                                <label for="enq_name"><i class="fas fa-user"></i> Full Name <span
                                        class="required">*</span></label>
                                <input type="text" id="enq_name" name="name" placeholder="Enter your full name"
                                    required>
                            </div>
                            <div class="enquiry-form-row">
                                <div class="enquiry-form-group">
                                    <label for="enq_email"><i class="fas fa-envelope"></i> Email <span
                                            class="required">*</span></label>
                                    <input type="email" id="enq_email" name="email" placeholder="email@example.com"
                                        required>
                                </div>
                                <div class="enquiry-form-group">
                                    <label for="enq_phone"><i class="fas fa-phone"></i> Phone <span
                                            class="required">*</span></label>
                                    <input type="tel" id="enq_phone" name="phone" placeholder="10-digit number"
                                        required>
                                </div>
                            </div>
                            <div class="enquiry-form-group">
                                <label for="enq_class"><i class="fas fa-chalkboard"></i> Student Class <span
                                        class="required">*</span></label>
                                <select id="enq_class" name="studentClass" required>
                                    <option value="" disabled selected>Select Class</option>
                                    <option value="Nursery">Nursery</option>
                                    <option value="LKG">LKG</option>
                                    <option value="UKG">UKG</option>
                                    <option value="Class 1">Class 1</option>
                                    <option value="Class 2">Class 2</option>
                                    <option value="Class 3">Class 3</option>
                                    <option value="Class 4">Class 4</option>
                                    <option value="Class 5">Class 5</option>
                                    <option value="Class 6">Class 6</option>
                                    <option value="Class 7">Class 7</option>
                                    <option value="Class 8">Class 8</option>
                                    <option value="Class 9">Class 9</option>
                                    <option value="Class 10">Class 10</option>
                                    <option value="Class 11 - Science">Class 11 - Science</option>
                                    <option value="Class 11 - Commerce">Class 11 - Commerce</option>
                                    <option value="Class 11 - Arts">Class 11 - Arts</option>
                                    <option value="Class 12 - Science">Class 12 - Science</option>
                                    <option value="Class 12 - Commerce">Class 12 - Commerce</option>
                                    <option value="Class 12 - Arts">Class 12 - Arts</option>
                                </select>
                            </div>
                            <div class="enquiry-form-group">
                                <label for="enq_message"><i class="fas fa-comment-dots"></i> Message <span
                                        class="required">*</span></label>
                                <textarea id="enq_message" name="message" rows="3"
                                    placeholder="Your message or query..." required></textarea>
                            </div>
                            <div id="enquiryError" class="enquiry-error" style="display:none;"></div>
                            <button type="submit" class="enquiry-submit-btn" id="enquirySubmitBtn">
                                <span class="btn-text">Submit Enquiry</span>
                                <span class="btn-loader" style="display:none;"><i class="fas fa-spinner fa-spin"></i>
                                    Submitting...</span>
                            </button>
                        </form>
                    </div>

                    <!-- Thank You View -->
                    <div id="enquiryThankYou" class="enquiry-thankyou" style="display:none;">
                        <div class="thankyou-icon">
                            <i class="fas fa-check-circle"></i>
                        </div>
                        <h2>Thank You!</h2>
                        <p>Your enquiry has been submitted successfully.</p>
                        <div class="enquiry-number-box">
                            <span class="enquiry-number-label">Your Enquiry Number</span>
                            <span class="enquiry-number-value" id="enquiryNumberDisplay"></span>
                        </div>
                        <p class="thankyou-note" id="emailStatusMsg">A confirmation email has been sent to your email
                            address.</p>
                        <button class="enquiry-submit-btn" onclick="closeEnquiryModal()"
                            style="margin-top: 20px;">Close</button>
                    </div>
                </div>
            </div>

            <style>
                /* Floating Button - Right side vertical tab */
                .enquire-float-btn {
                    position: fixed;
                    top: 50%;
                    right: 0;
                    transform: translateY(-50%);
                    z-index: 9999;
                    background: #d3bf09;
                    color: white;
                    border: none;
                    padding: 18px 12px;
                    border-radius: 8px 0 0 8px;
                    font-size: 0.95rem;
                    font-weight: 700;
                    cursor: pointer;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    writing-mode: vertical-rl;
                    text-orientation: mixed;
                    letter-spacing: 1.5px;
                    text-transform: uppercase;
                    box-shadow: -4px 0 15px rgba(0, 0, 0, 0.2);
                    transition: all 0.3s ease;
                    gap: 8px;
                }

                .enquire-float-btn:hover {
                    padding-right: 18px;
                    box-shadow: -6px 0 25px rgba(0, 0, 0, 0.3);
                    background: #218838;
                }

                .enquire-float-btn i {
                    font-size: 1rem;
                    writing-mode: horizontal-tb;
                }

                /* Modal Overlay */
                .enquiry-modal-overlay {
                    display: none;
                    position: fixed;
                    top: 0;
                    left: 0;
                    right: 0;
                    bottom: 0;
                    background: rgba(0, 0, 0, 0.6);
                    backdrop-filter: blur(4px);
                    z-index: 10000;
                    justify-content: center;
                    align-items: center;
                    padding: 20px;
                    opacity: 0;
                    transition: opacity 0.3s ease;
                }

                .enquiry-modal-overlay.active {
                    display: flex;
                    opacity: 1;
                }

                /* Modal Box */
                .enquiry-modal {
                    background: white;
                    border-radius: 16px;
                    width: 100%;
                    max-width: 520px;
                    max-height: 90vh;
                    overflow-y: auto;
                    padding: 35px 30px;
                    position: relative;
                    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3);
                    transform: translateY(30px);
                    transition: transform 0.3s ease;
                }

                .enquiry-modal-overlay.active .enquiry-modal {
                    transform: translateY(0);
                }

                .enquiry-modal-close {
                    position: absolute;
                    top: 15px;
                    right: 18px;
                    background: none;
                    border: none;
                    font-size: 2rem;
                    color: #999;
                    cursor: pointer;
                    line-height: 1;
                    transition: color 0.2s;
                }

                .enquiry-modal-close:hover {
                    color: #333;
                }

                /* Modal Header */
                .enquiry-modal-header {
                    text-align: center;
                    margin-bottom: 25px;
                }

                .enquiry-modal-icon {
                    width: 60px;
                    height: 60px;
                    background: linear-gradient(135deg, #0a2647, #144272);
                    border-radius: 50%;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    margin: 0 auto 15px auto;
                }

                .enquiry-modal-icon i {
                    color: #FFD700;
                    font-size: 1.5rem;
                }

                .enquiry-modal-header h2 {
                    color: #0a2647;
                    font-size: 1.6rem;
                    margin: 0 0 8px 0;
                }

                .enquiry-modal-header p {
                    color: #777;
                    font-size: 0.95rem;
                    margin: 0;
                }

                /* Form Styles */
                .enquiry-form-group {
                    margin-bottom: 16px;
                }

                .enquiry-form-group label {
                    display: block;
                    font-size: 0.85rem;
                    font-weight: 600;
                    color: #0a2647;
                    margin-bottom: 6px;
                }

                .enquiry-form-group label i {
                    color: #144272;
                    margin-right: 5px;
                    font-size: 0.8rem;
                }

                .enquiry-form-group label .required {
                    color: #e74c3c;
                }

                .enquiry-form-group input,
                .enquiry-form-group select,
                .enquiry-form-group textarea {
                    width: 100%;
                    padding: 11px 14px;
                    border: 1.5px solid #ddd;
                    border-radius: 8px;
                    font-size: 0.95rem;
                    font-family: inherit;
                    transition: border-color 0.3s, box-shadow 0.3s;
                    background: #fafafa;
                    box-sizing: border-box;
                }

                .enquiry-form-group input:focus,
                .enquiry-form-group select:focus,
                .enquiry-form-group textarea:focus {
                    outline: none;
                    border-color: #0a2647;
                    box-shadow: 0 0 0 3px rgba(10, 38, 71, 0.1);
                    background: white;
                }

                .enquiry-form-group select {
                    appearance: auto;
                    cursor: pointer;
                }

                .enquiry-form-row {
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                    gap: 14px;
                }

                .enquiry-error {
                    background: #fef2f2;
                    color: #dc2626;
                    padding: 10px 14px;
                    border-radius: 8px;
                    font-size: 0.9rem;
                    margin-bottom: 14px;
                    border: 1px solid #fecaca;
                }

                .enquiry-submit-btn {
                    width: 100%;
                    padding: 14px;
                    background: linear-gradient(135deg, #0a2647, #144272);
                    color: #FFD700;
                    border: none;
                    border-radius: 10px;
                    font-size: 1.05rem;
                    font-weight: 600;
                    cursor: pointer;
                    transition: all 0.3s ease;
                    letter-spacing: 0.3px;
                }

                .enquiry-submit-btn:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 20px rgba(10, 38, 71, 0.3);
                }

                .enquiry-submit-btn:disabled {
                    opacity: 0.7;
                    cursor: not-allowed;
                    transform: none;
                }

                /* Thank You View */
                .enquiry-thankyou {
                    text-align: center;
                    padding: 20px 0;
                }

                .thankyou-icon {
                    font-size: 4rem;
                    color: #22c55e;
                    margin-bottom: 15px;
                    animation: thankScale 0.5s ease;
                }

                @keyframes thankScale {
                    0% {
                        transform: scale(0);
                    }

                    50% {
                        transform: scale(1.2);
                    }

                    100% {
                        transform: scale(1);
                    }
                }

                .enquiry-thankyou h2 {
                    color: #0a2647;
                    font-size: 1.8rem;
                    margin: 0 0 10px 0;
                }

                .enquiry-thankyou p {
                    color: #555;
                    font-size: 1rem;
                    margin: 0 0 20px 0;
                }

                .enquiry-number-box {
                    background: linear-gradient(135deg, #f0f9ff, #e0f2fe);
                    border: 2px dashed #0a2647;
                    border-radius: 12px;
                    padding: 18px;
                    margin: 20px 0;
                    display: flex;
                    flex-direction: column;
                    gap: 6px;
                }

                .enquiry-number-label {
                    font-size: 0.8rem;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    color: #666;
                    font-weight: 600;
                }

                .enquiry-number-value {
                    font-size: 1.8rem;
                    font-weight: 700;
                    color: #0a2647;
                    letter-spacing: 2px;
                }

                .thankyou-note {
                    font-size: 0.9rem !important;
                    color: #888 !important;
                }

                /* Mobile */
                @media (max-width: 768px) {
                    .enquire-float-btn {
                        padding: 14px 10px;
                        font-size: 0.8rem;
                        letter-spacing: 1px;
                    }

                    .enquiry-modal {
                        padding: 25px 18px;
                        max-height: 95vh;
                        margin: 10px;
                        border-radius: 12px;
                    }

                    .enquiry-modal-header h2 {
                        font-size: 1.3rem;
                    }

                    .enquiry-modal-header p {
                        font-size: 0.85rem;
                    }

                    .enquiry-form-row {
                        grid-template-columns: 1fr;
                        gap: 0;
                    }

                    .enquiry-number-value {
                        font-size: 1.3rem;
                    }

                    .enquiry-modal-icon {
                        width: 50px;
                        height: 50px;
                    }

                    .enquiry-modal-icon i {
                        font-size: 1.2rem;
                    }
                }

                @media (max-width: 400px) {
                    .enquire-float-btn {
                        padding: 12px 8px;
                        font-size: 0.7rem;
                    }
                }
            </style>

            <script>
                function openEnquiryModal() {
                    const modal = document.getElementById('enquiryModal');
                    modal.style.display = 'flex';
                    // Trigger animation
                    requestAnimationFrame(() => {
                        modal.classList.add('active');
                    });
                    document.body.style.overflow = 'hidden';
                }

                function closeEnquiryModal() {
                    const modal = document.getElementById('enquiryModal');
                    modal.classList.remove('active');
                    setTimeout(() => {
                        modal.style.display = 'none';
                        document.body.style.overflow = '';
                        // Reset form
                        document.getElementById('enquiryForm').reset();
                        document.getElementById('enquiryFormView').style.display = '';
                        document.getElementById('enquiryThankYou').style.display = 'none';
                        document.getElementById('enquiryError').style.display = 'none';
                    }, 300);
                }

                function closeEnquiryModalOutside(e) {
                    if (e.target === e.currentTarget) closeEnquiryModal();
                }

                async function submitEnquiry(e) {
                    e.preventDefault();
                    const errorEl = document.getElementById('enquiryError');
                    const submitBtn = document.getElementById('enquirySubmitBtn');
                    const btnText = submitBtn.querySelector('.btn-text');
                    const btnLoader = submitBtn.querySelector('.btn-loader');

                    errorEl.style.display = 'none';

                    const name = document.getElementById('enq_name').value.trim();
                    const email = document.getElementById('enq_email').value.trim();
                    const phone = document.getElementById('enq_phone').value.trim();
                    const studentClass = document.getElementById('enq_class').value;
                    const message = document.getElementById('enq_message').value.trim();

                    // Client-side validation
                    if (!name || !email || !phone || !studentClass || !message) {
                        errorEl.textContent = 'Please fill in all required fields.';
                        errorEl.style.display = 'block';
                        return;
                    }
                    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                    if (!emailRegex.test(email)) {
                        errorEl.textContent = 'Please enter a valid email address.';
                        errorEl.style.display = 'block';
                        return;
                    }
                    if (!/^[0-9]{10}$/.test(phone.replace(/[\s\-]/g, ''))) {
                        errorEl.textContent = 'Please enter a valid 10-digit phone number.';
                        errorEl.style.display = 'block';
                        return;
                    }

                    // Show loading
                    submitBtn.disabled = true;
                    btnText.style.display = 'none';
                    btnLoader.style.display = 'inline';

                    try {
                        const response = await fetch('/school/enquiry', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ name, email, phone, studentClass, message })
                        });
                        const data = await response.json();

                        if (data.success) {
                            // Show thank you
                            document.getElementById('enquiryFormView').style.display = 'none';
                            document.getElementById('enquiryThankYou').style.display = 'block';
                            document.getElementById('enquiryNumberDisplay').textContent = data.enquiryNumber;

                            if (data.emailSent) {
                                document.getElementById('emailStatusMsg').textContent = 'A confirmation email has been sent to your email address.';
                            } else {
                                document.getElementById('emailStatusMsg').textContent = 'Please save your enquiry number for future reference. Our team will contact you soon.';
                            }
                        } else {
                            errorEl.textContent = data.error || 'Something went wrong. Please try again.';
                            errorEl.style.display = 'block';
                        }
                    } catch (err) {
                        errorEl.textContent = 'Network error. Please check your connection and try again.';
                        errorEl.style.display = 'block';
                    } finally {
                        submitBtn.disabled = false;
                        btnText.style.display = 'inline';
                        btnLoader.style.display = 'none';
                    }
                }
            </script>
</body>

</html>